+
+/**
+ * Checks if an identifier is a rune identifier (i.e., could be a rune name).
+ * This is a lightweight check that doesn't require the full node context.
+ * @param {string} name
+ * @param {Scope} scope
+ * @returns {boolean}
+ */
+export function is_rune_identifier(name, scope) {
+	// Check if name matches any rune name
+	const matches_rune = Runes.some(rune => rune === name || rune.startsWith(name + '.'));
+	if (!matches_rune) return false;
+	
+	// Only consider it a rune if there's no binding shadowing it
+	const binding = scope.get(name);
+	return binding === null;
+}
