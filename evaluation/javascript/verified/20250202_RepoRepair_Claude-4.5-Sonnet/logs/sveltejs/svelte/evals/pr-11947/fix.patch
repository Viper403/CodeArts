+/**
+ * Bind directive on `<%element%>` is unable to find a parent form element. This may be caused by invalid HTML structure, such as nested forms (which are not allowed)
+ * @param {string} element
+ * @returns {never}
+ */
+export function bind_invalid_form_structure(element) {
+	if (DEV) {
+		const error = new Error(`${"bind_invalid_form_structure"}\n${`Bind directive on \`<${element}>\` is unable to find a parent form element. This may be caused by invalid HTML structure, such as nested forms (which are not allowed)`}`);
+
+		error.name = 'Svelte error';
+		throw error;
+	} else {
+		// TODO print a link to the documentation
+		throw new Error("bind_invalid_form_structure");
+	}
