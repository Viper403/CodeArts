+/**
+ * Input types that are safe to use with dynamic type attribute and two-way binding
+ * These types all behave similarly to text inputs in terms of value binding
+ */
+const BINDABLE_INPUT_TYPES = new Set([
+	'text',
+	'email',
+	'password',
+	'search',
+	'tel',
+	'url',
+	'number',
+	'date',
+	'datetime-local',
+	'month',
+	'time',
+	'week',
+	'color'
+]);
+
+/**
+ * Checks if an input type is safe for dynamic type with two-way binding
+ * @param {string} type
+ * @returns {boolean}
+ */
+export function is_bindable_input_type(type) {
+	return BINDABLE_INPUT_TYPES.has(type);
+}
 
