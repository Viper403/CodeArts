+/**
+ * Validate that a prop with a default value is not being mutated.
+ * Props are readonly unless used with `bind:`, and their default values should also be readonly.
+ * @param {any} value
+ * @param {string} prop_name
+ * @returns {any}
+ */
+export function validate_prop_readonly(value, prop_name) {
+	if (typeof value === 'object' && value !== null) {
+		return new Proxy(value, {
+			set(target, property, new_value) {
+				throw new Error(
+					`Cannot mutate a default value for prop '${prop_name}'. Props are readonly unless used with \`bind:\`.`
+				);
+			},
+			deleteProperty(target, property) {
+				throw new Error(
+					`Cannot mutate a default value for prop '${prop_name}'. Props are readonly unless used with \`bind:\`.`
+				);
+			}
+		});
+	}
+	return value;
+}
