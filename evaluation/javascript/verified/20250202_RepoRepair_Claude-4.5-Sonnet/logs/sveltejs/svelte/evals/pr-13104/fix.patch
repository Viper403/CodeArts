+/**
+ * %name% is updated, but is not declared with `$state(...)`. Changing its value will not correctly trigger updates
+ * @param {string} name
+ */
+export function non_reactive_update(name) {
+	if (DEV) {
+		console.warn(`%c[svelte] non_reactive_update\n%c${name} is updated, but is not declared with \`$state(...)\`. Changing its value will not correctly trigger updates`, bold, normal);
+	} else {
+		// TODO print a link to the documentation
+		console.warn("non_reactive_update");
+	}
